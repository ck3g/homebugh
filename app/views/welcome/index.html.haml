/ Hero Section
.welcome-hero
  .container
    = render 'shared/flash_messages'
    %h1.welcome-hero-title= t('welcome_page.hero_title')
    %p.welcome-hero-subtitle= t('welcome_page.hero_subtitle')
    .welcome-hero-buttons
      = link_to new_user_registration_path, class: "btn-pill-hero-primary" do
        = t("welcome_page.create_account_button")
      = link_to new_user_session_path, class: "btn-pill-hero-secondary" do
        = t("welcome_page.sign_in_button")

/ Feature Grid
.welcome-features
  .welcome-grid
    / Row 1: Transactions (wide) + Accounts (small)
    .welcome-card.welcome-card-wide
      .welcome-card-content
        .welcome-card-label= t('welcome_page.features.transactions.title')
        .welcome-card-title= t('welcome_page.features.transactions.description')
        %p.welcome-card-text= t('welcome_page.features.transactions.short_description')
      .welcome-viz
        .welcome-viz-bars
          .bar{style: "height: 18px; background: #a3d9a3;"}
          .bar{style: "height: 30px; background: #7ec87e;"}
          .bar{style: "height: 22px; background: #5cb85c;"}
          .bar{style: "height: 40px; background: #47a447;"}
          .bar{style: "height: 34px; background: #3a8a3a;"}

    .welcome-card.welcome-card-small
      .welcome-card-icon
        = fa_icon "credit-card"
      .welcome-card-title= t('welcome_page.features.accounts.title')
      %p.welcome-card-text= t('welcome_page.features.accounts.short_description')

    / Row 2: Categories (small) + Budgets (wide)
    .welcome-card.welcome-card-small
      .welcome-card-icon
        = fa_icon "tags"
      .welcome-card-title= t('welcome_page.features.categories.title')
      %p.welcome-card-text= t('welcome_page.features.categories.short_description')

    .welcome-card.welcome-card-wide
      .welcome-card-content
        .welcome-card-label= t('welcome_page.features.budgets.title')
        .welcome-card-title= t('welcome_page.features.budgets.description')
        %p.welcome-card-text= t('welcome_page.features.budgets.short_description')
      .welcome-viz-progress
        .progress-row
          .progress-label Food
          .progress-track
            .progress-fill{style: "width: 65%; background: #47a447;"}
        .progress-row
          .progress-label Transport
          .progress-track
            .progress-fill{style: "width: 40%; background: #5cb85c;"}
        .progress-row
          .progress-label Shopping
          .progress-track
            .progress-fill{style: "width: 88%; background: #e8a735;"}

    / Row 3: Reports (wide) + Recurring (small)
    .welcome-card.welcome-card-wide
      .welcome-card-content
        .welcome-card-label= t('welcome_page.features.statistics.title')
        .welcome-card-title= t('welcome_page.features.statistics.description')
        %p.welcome-card-text= t('welcome_page.features.statistics.short_description')
      .welcome-viz-pie
        %svg{width: "50", height: "50", viewBox: "0 0 50 50"}
          %circle{cx: "25", cy: "25", r: "20", fill: "none", stroke: "#e2f2e2", "stroke-width": "8"}
          %circle{cx: "25", cy: "25", r: "20", fill: "none", stroke: "#47a447", "stroke-width": "8", "stroke-dasharray": "50 126", "stroke-dashoffset": "0", transform: "rotate(-90 25 25)"}
          %circle{cx: "25", cy: "25", r: "20", fill: "none", stroke: "#7ec87e", "stroke-width": "8", "stroke-dasharray": "35 126", "stroke-dashoffset": "-50", transform: "rotate(-90 25 25)"}
          %circle{cx: "25", cy: "25", r: "20", fill: "none", stroke: "#a3d9a3", "stroke-width": "8", "stroke-dasharray": "25 126", "stroke-dashoffset": "-85", transform: "rotate(-90 25 25)"}

    .welcome-card.welcome-card-small
      .welcome-card-icon
        = fa_icon "repeat"
      .welcome-card-title= t('welcome_page.features.recurring.title')
      %p.welcome-card-text= t('welcome_page.features.recurring.short_description')

/ CTA Section
.welcome-cta-wrapper
  .welcome-cta
    %h2.welcome-cta-title= t('welcome_page.cta.title')
    %p.welcome-cta-subtitle= t('welcome_page.cta.subtitle')
    = link_to new_user_registration_path, class: "btn-pill-hero-primary" do
      = t("welcome_page.create_account_button")


