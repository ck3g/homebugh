          = link_to image_tag("flags/#{inverse_locale}.png"), url_for(locale: inverse_locale), class: "nav-link"
        %li.nav-item
          = link_to t("welcome_page.sign_in_button"), new_user_session_path, class: "nav-link nav-link-green"
        %li.nav-item.ms-2
          = link_to t("welcome_page.get_started_button"), new_user_registration_path, class: "btn btn-pill-green"
