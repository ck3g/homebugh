%h2.auth-form-title= t(:resend_unlock_instructions, default: "Resend unlock instructions")
%p.auth-form-subtitle= t(:unlock_subtitle, default: "We'll send you a link to unlock your account")

= simple_form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "auth-form" }) do |f|
  .mb-3
    = f.input_field :email, autofocus: true, placeholder: t(:email), class: "form-control #{'is-invalid' if resource.errors[:email].present?}"
    - if resource.errors[:email].present?
      .invalid-feedback
        = f.error :email
  = f.button :submit, t(:resend_unlock_instructions, default: "Resend unlock instructions"), class: "auth-submit"

.auth-links
  %span
    = t(:already_unlocked, default: "Already unlocked?")
    = link_to t(:sign_in), new_session_path(resource_name)
  - if devise_mapping.registerable?
    %span
      = t(:no_account, default: "Don't have an account?")
      = link_to t(:sign_up), new_registration_path(resource_name)
