%h2.auth-form-title= t(:resend_confirmation_instructions)
%p.auth-form-subtitle= t(:confirmation_subtitle, default: "We'll resend the confirmation email")

= simple_form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { class: "auth-form" }) do |f|
  .mb-3
    = f.input_field :email, autofocus: true, placeholder: t(:email), class: "form-control #{'is-invalid' if resource.errors[:email].present?}"
    - if resource.errors[:email].present?
      .invalid-feedback
        = f.error :email
  = f.button :submit, t(:resend_confirmation_instructions), class: "auth-submit"

.auth-links
  %span
    = t(:already_confirmed, default: "Already confirmed?")
    = link_to t(:sign_in), new_session_path(resource_name)
  - if devise_mapping.registerable?
    %span
      = t(:no_account, default: "Don't have an account?")
      = link_to t(:sign_up), new_registration_path(resource_name)
