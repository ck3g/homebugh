%h2.auth-form-title= t(:forgot_your_password)
%p.auth-form-subtitle= t(:forgot_password_subtitle, default: "We'll send you a link to reset it")

= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "auth-form" }) do |f|
  .mb-3
    = f.input_field :email, required: true, autofocus: true, placeholder: t(:email), class: "form-control #{'is-invalid' if resource.errors[:email].present?}"
    - if resource.errors[:email].present?
      .invalid-feedback
        = f.error :email
  = f.button :submit, t(:send_me_reset_password_instructions), class: "auth-submit"

.auth-links
  %span
    = t(:remember_password, default: "Remember your password?")
    = link_to t(:sign_in), new_session_path(resource_name)
  - if devise_mapping.registerable?
    %span
      = t(:no_account, default: "Don't have an account?")
      = link_to t(:sign_up), new_registration_path(resource_name)
